# Copy this file to ".env" and fill in your own values.

# PostgreSQL connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vitaherbs

# Port the API server listens on.
PORT=4000

# Comma-separated list of origins allowed to call the API (your frontend).
# Vite dev server defaults to http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Admin dashboard login credentials.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Secret used to sign admin login tokens. Use a long random string in production.
JWT_SECRET=replace-with-a-long-random-secret
